# =============================================================================
# ConcreteIQ Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# Environment: "development" or "production"
ENVIRONMENT=development
# DEBUG=true  # Only set explicitly for local dev; defaults to false

# Database (PostgreSQL required for production)
DATABASE_URL=postgresql+asyncpg://concreteiq:concreteiq@localhost:5432/concreteiq

# Security (REQUIRED — generate strong random values for production)
# SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
# ADMIN_PASSWORD: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD=$2b$12$YOUR_BCRYPT_HASH_HERE

# PII Encryption (recommended for production)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Business Details (KRG Concreting)
BUSINESS_NAME=Kyle R Gyoles
TRADING_AS=KRG Concreting
ABN=76 993 685 401
LICENCE_NUMBER=374931C
BUSINESS_PHONE=0423 005 129
BUSINESS_EMAIL=kyle@krgconcreting.au
BUSINESS_ADDRESS=Thurgoona NSW 2640

# Bank Details (for invoices)
BANK_NAME=Commonwealth Bank
BANK_BSB=062-000
BANK_ACCOUNT=1234 5678

# App URL (MUST be HTTPS in production)
APP_URL=http://localhost:8010

# Redis (for Celery background tasks)
REDIS_URL=redis://localhost:6379/0

# Webhook Authentication (shared secret for Postmark/ClickSend/Vonage callbacks)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Add as ?token=YOUR_SECRET in webhook URL configurations
WEBHOOK_SECRET=

# Integrations (optional — leave blank if not using)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
POSTMARK_API_KEY=
POSTMARK_FROM_EMAIL=quotes@krgconcreting.au
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=
GOOGLE_CALENDAR_ID=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_REVIEW_URL=

# Storage (Cloudflare R2 / S3-compatible)
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=concreteiq-photos
R2_ENDPOINT=
R2_PUBLIC_URL=
